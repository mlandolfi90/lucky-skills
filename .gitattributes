# Cadena de integridad: forjar-release.sh hashea con sha256_lf (LF) y `cargar`
# verifica sobre LF. Forzamos LF en TODO el repo para que el raw servido a
# `cargar` sea byte-idéntico al que se hashea — evita drift CRLF, sobre todo en
# UTF-8 multibyte. Salda la deuda hallada por el plan i18n
# (docs/refactor/_crisol/PLAN-i18n-costura.md).
* text=auto eol=lf

# Texto explícito (LF innegociable): scripts ejecutables (corren en Linux/Git-Bash),
# config y prosa sellada.
*.sh       text eol=lf
*.py       text eol=lf
*.ps1      text eol=lf
*.md       text eol=lf
*.json     text eol=lf
.gitignore text eol=lf

# Binarios (defensivo, para cuando se agreguen): NO normalizar EOL. En especial
# *.minisig — una firma minisign normalizada a LF quedaría CORROMPIDA.
*.minisig  binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.pdf      binary
*.ico      binary
*.woff     binary
*.woff2    binary

# ADR 0016 — proyecciones GENERADAS (scripts/proyectar.py): no editar a mano;
# colapsadas en los diffs de GitHub. El sellado sha256 va sobre bytes LF (ya
# forzado arriba por `* text=auto eol=lf`).
docs/refactor/_crisol/RUN-LEDGER.md linguist-generated=true
docs/refactor/_crisol/_ACTIVE       linguist-generated=true text eol=lf
docs/decisions/INDEX.md             linguist-generated=true
docs/hotfixs/INDICE.md              linguist-generated=true
*.yaml text eol=lf
